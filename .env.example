# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/athens_recycling"

# AI Fallback - OpenAI-compatible endpoint
# For OpenRouter (MiniMax, etc): https://openrouter.ai/api/v1
# For local LLM (Ollama): http://localhost:11434/v1
# For OpenAI: https://api.openai.com/v1
AI_API_BASE_URL="https://openrouter.ai/api/v1"
AI_API_KEY="your-api-key-here"
AI_MODEL="minimax/m2.7" # or your preferred model

# App
NEXT_PUBLIC_APP_URL="https://recycleathens.com"
NODE_ENV="development"

# Auth (NextAuth.js v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Analytics - leave blank to disable
# Works with Umami, Plausible, Fathom, Matomo, or any script-tag analytics
# Umami:    SCRIPT_URL=https://your-umami.com/script.js  SITE_ID=your-website-id
# Plausible: SCRIPT_URL=https://plausible.io/js/script.js (no SITE_ID needed)
# Fathom:   SCRIPT_URL=https://cdn.usefathom.com/script.js  SITE_ID=your-site-id
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=""
NEXT_PUBLIC_ANALYTICS_SITE_ID=""
